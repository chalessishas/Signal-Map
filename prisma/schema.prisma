generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Building {
  id          String   @id @default(cuid())
  name        String
  description String?
  lat         Float
  lng         Float
  campus      String   @default("OTHER") // NORTH | SOUTH | OTHER
  aliases     String   @default("[]") // JSON array of strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events     Event[]
  userEvents UserEvent[]
  comments   Comment[]
}

model Event {
  id           String   @id @default(cuid())
  sourceId     String?  @unique
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime?
  buildingId   String?
  locationText String?
  organizer    String?
  category     String?
  isCLE        Boolean  @default(false)
  status       String   @default("ACTIVE") // ACTIVE | CANCELLED
  sourceRef    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  comments Comment[]

  @@index([buildingId])
  @@index([startTime])
  @@index([status])
  @@index([category])
}

model EventSource {
  id            String    @id @default(cuid())
  name          String
  url           String
  parserType    String // RSS | HTML | API
  lastSuccessAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ingestLogs IngestLog[]
}

model IngestLog {
  id           String   @id @default(cuid())
  sourceId     String
  runAt        DateTime @default(now())
  newCount     Int      @default(0)
  updatedCount Int      @default(0)
  errorCount   Int      @default(0)
  rawError     String?

  source EventSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id        String   @id // matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions UserEvent[]
  comments    Comment[]
}

model UserEvent {
  id           String    @id @default(cuid())
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime?
  buildingId   String?
  locationText String?
  category     String?
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  authorId     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  author   UserProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  building Building?   @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([buildingId])
  @@index([status])
  @@index([startTime])
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  authorId   String
  eventId    String?
  buildingId String?
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   UserProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event    Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  building Building?   @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  parent   Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[]   @relation("CommentReplies")

  @@index([eventId])
  @@index([buildingId])
  @@index([authorId])
}

model NewscastEpisode {
  id          String   @id @default(cuid())
  date        DateTime @unique // one episode per day, stored as midnight ET
  title       String   // "Tar Heel Morning Brief — Apr 1, 2026"
  script      String   // full broadcast text
  audioUrl    String?  // path to stored MP3/WAV
  audioBase64 String?  // inline base64 audio (fallback if no storage)
  durationSec Int?     // audio duration in seconds
  sources     String   @default("[]") // JSON: [{title, url, source}]
  weather     String?  // JSON: {temp, condition, high, low}
  createdAt   DateTime @default(now())

  @@index([date])
}
