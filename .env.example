# Supabase PostgreSQL (get from Supabase Dashboard → Connect button)
# IMPORTANT: Use the exact pooler hostname from your project's Connect dialog (may be aws-0 or aws-1)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-[N]-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-[N]-us-east-1.pooler.supabase.com:5432/postgres"
ADMIN_TOKEN="change-me-to-a-secret"
