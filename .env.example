# Supabase PostgreSQL (get from Supabase Dashboard → Connect button)
# IMPORTANT: Use the exact pooler hostname from your project's Connect dialog (may be aws-0 or aws-1)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-[N]-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-[N]-us-east-1.pooler.supabase.com:5432/postgres"
ADMIN_TOKEN="change-me-to-a-secret"

# Radio (AI announcements)
DEEPSEEK_API_KEY="sk-your-deepseek-key"
DASHSCOPE_API_KEY="sk-your-dashscope-key"

# Normalizer diagnostics (optional)
# Set to "1" to enable console.warn logging of unmatched event locations in
# src/lib/ingest/normalizer.ts. Useful for ~1 week of data collection to
# identify high-frequency unresolved locationText, then expand DIRECT_MAPPINGS
# data-driven. Default off to keep prod logs clean.
SIGNAL_MAP_LOG_UNMATCHED="0"
